generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model HeroContent {
  id                String @id @default("default")
  eyebrow           String
  slogan            String
  subcopy           String
  primaryCtaLabel   String @map("primary_cta_label")
  primaryCtaHref    String @map("primary_cta_href")
  secondaryCtaLabel String @map("secondary_cta_label")
  secondaryCtaHref  String @map("secondary_cta_href")
  imageAssetKey     String @map("image_asset_key")
  imageAlt          String @map("image_alt")
  imageAspectRatio  Float? @map("image_aspect_ratio")
  imageExt          String? @map("image_ext")

  @@map("hero_content")
}

model BrandStory {
  id                     String @id @default("default")
  eyebrow                String
  title                  String
  paragraphs             Json
  nameMeaningReading     String @map("name_meaning_reading")
  nameMeaningMeaning     String @map("name_meaning_meaning")
  imageAssetKey          String @map("image_asset_key")
  imageAlt               String @map("image_alt")
  imageAspectRatio       Float? @map("image_aspect_ratio")
  imageExt               String? @map("image_ext")

  @@map("brand_story")
}

model SilkFeature {
  id             String @id @default(uuid())
  label          String
  title          String
  description    String
  imageAssetKey  String? @map("image_asset_key")
  imageAlt       String? @map("image_alt")
  imageAspectRatio Float? @map("image_aspect_ratio")
  imageExt       String? @map("image_ext")
  sortOrder      Int     @default(0) @map("sort_order")

  @@map("silk_feature")
}

model Category {
  id            String @id @default(uuid())
  labelEn       String @map("label_en")
  title         String
  imageAssetKey String @map("image_asset_key")
  imageAlt      String @map("image_alt")
  imageAspectRatio Float? @map("image_aspect_ratio")
  imageExt      String? @map("image_ext")
  href          String
  sortOrder     Int     @default(0) @map("sort_order")

  @@map("category")
}

model BespokeContent {
  id            String @id @default("default")
  eyebrow       String
  title         String
  paragraphs    Json
  ctaLabel      String @map("cta_label")
  ctaHref       String @map("cta_href")
  imageAssetKey String @map("image_asset_key")
  imageAlt      String @map("image_alt")
  imageAspectRatio Float? @map("image_aspect_ratio")
  imageExt      String? @map("image_ext")

  @@map("bespoke_content")
}

model ProcessStep {
  id        String @id @default(uuid())
  stepId    String @map("step_id")
  icon      String
  title     String
  sortOrder Int    @default(0) @map("sort_order")

  @@map("process_step")
}

model Product {
  id           String @id
  name         String
  category     String
  material     String
  description  String
  imageAssetKey     String  @map("image_asset_key")
  imageAlt          String  @map("image_alt")
  imageAspectRatio  Float?  @map("image_aspect_ratio")
  imageExt          String? @map("image_ext")
  tags         Json
  story        String?
  specs        Json?
  care         Json?
  images       ProductImage[]
  sortOrder    Int     @default(0) @map("sort_order")

  @@map("product")
}

model ProductImage {
  id             String @id @default(uuid())
  productId      String @map("product_id")
  assetKey       String @map("asset_key")
  alt            String
  aspectRatio    Float? @map("aspect_ratio")
  ext            String?
  sortOrder      Int    @default(0) @map("sort_order")
  product        Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_image")
}

model GalleryItem {
  id             String @id @default(uuid())
  assetKey       String @map("asset_key")
  alt            String
  aspectRatio    Float? @map("aspect_ratio")
  ext            String?
  caption        String
  span           String
  sortOrder      Int    @default(0) @map("sort_order")

  @@map("gallery_item")
}

model ContactInfo {
  id            String @id @default("default")
  showroomName  String @map("showroom_name")
  address       String
  phone         String
  email         String
  hours         Json
  note          String
  socials       Json
  imageAssetKey String? @map("image_asset_key")
  imageAlt      String? @map("image_alt")
  imageAspectRatio Float? @map("image_aspect_ratio")
  imageExt      String? @map("image_ext")

  @@map("contact_info")
}
